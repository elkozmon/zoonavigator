{
  "compileOnSave": false,
  "compilerOptions": {
    "importHelpers": true,
    "outDir": "./dist/out-tsc",
    "baseUrl": "src",
    "sourceMap": true,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "strict": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "downlevelIteration": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types"
    ],
    "module": "es2015",
    "types": [
      "node"
    ]
  },
  "angularCompilerOptions": {
    "strictTemplates": true,
  }
}
